<cell id="abt-buy-cell-0002">import pandas as pd

# Read source tables and the perfect mapping
abt_df = pd.read_csv('Abt.csv', encoding='unicode_escape')
buy_df = pd.read_csv('Buy.csv', encoding='unicode_escape')
mapping_df = pd.read_csv('abt_buy_perfectMapping.csv', encoding='unicode_escape')

# Concat into one frame. Buy has 'manufacturer', Abt doesn't.
combined_df = pd.concat([abt_df, buy_df], ignore_index=True)

# The mapping has a few many-to-many entries (one Abt record matched to
# multiple Buy records or vice versa). Walk the bipartite graph with
# union-find so co-matched records land in a single group_id, not a chain
# of pairwise groups.
parent = {}
def find(x):
    while parent.get(x, x) != x:
        parent[x] = parent.get(parent[x], parent[x])
        x = parent[x]
    return x
def union(a, b):
    ra, rb = find(a), find(b)
    if ra != rb:
        parent[ra] = rb

# Tag with table prefix so idAbt and idBuy don't collide
for _, row in mapping_df.iterrows():
    a, b = ('abt', int(row['idAbt'])), ('buy', int(row['idBuy']))
    parent.setdefault(a, a)
    parent.setdefault(b, b)
    union(a, b)

# Assign one group_id per connected component
roots = {}
def gid(table, raw_id):
    key = (table, int(raw_id))
    if key not in parent:
        return None
    root = find(key)
    if root not in roots:
        roots[root] = len(roots) + 1
    return roots[root]

combined_df['_table'] = ['abt'] * len(abt_df) + ['buy'] * len(buy_df)
combined_df['group_id'] = combined_df.apply(lambda r: gid(r['_table'], r['id']), axis=1)
combined_df = combined_df.drop(columns=['_table'])

# Renumber id sequentially, preserving the original under original_id
combined_df = combined_df.sort_values(by='group_id', ascending=True, na_position='last')
combined_df['original_id'] = combined_df['id']
combined_df['id'] = range(1, len(combined_df) + 1)

combined_df.to_csv('CombinedProducts.csv', index=False)</cell id="abt-buy-cell-0002">